# En el VPS (detrás de Caddy con HTTPS real): NODE_ENV=production y
# APP_URL=https://cuentas.tu-dominio.com — el protocolo de APP_URL es
# lo único que le dice a la app si debe marcar la cookie de sesión como
# Secure y mandar HSTS (Caddy ya termina la TLS, la app en sí nunca ve la
# conexión HTTPS directamente).
NODE_ENV=development
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=CuentasClaras

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cuentas_claras

STORAGE_MODE=local
STORAGE_LOCAL_ROOT=./storage/documents
MAX_UPLOAD_MB=20

MISTRAL_API_KEY=replace_with_real_key
MISTRAL_BASE_URL=https://api.mistral.ai
MISTRAL_MODEL=mistral-medium-latest
MISTRAL_OCR_MODEL=mistral-ocr-latest
MISTRAL_EXTRACT_MODEL=mistral-small-latest

# OPCIONAL — URL base de una API externa de catálogo/comparación de precios
# de supermercados, usada por la búsqueda online de la lista de súper.
# Si queda vacía, esa búsqueda se deshabilita silenciosamente y los productos
# se cargan de forma manual (ítems libres); el resto de la app no cambia.
# El contrato de endpoints que la app espera está documentado en
# lib/server/price-catalog.ts:
#   GET {BASE_URL}/api/products/search?q=&offset=&limit=
#   GET {BASE_URL}/api/products/{id}/prices
PRICE_CATALOG_BASE_URL=

QUEUE_CONCURRENCY=2
INGEST_WORKER_POLL_MS=1200

# Controla si el endpoint /register está abierto. Con "true" cualquiera puede
# crear una cuenta (ideal para uso multi-usuario o auto-hospedaje público).
# Poné "false" si querés cerrar el registro una vez que ya tengas los usuarios
# que necesitás.
REGISTRATION_ENABLED=true

# "true" SOLO si hay un proxy inverso propio (nginx/Caddy/Traefik/load
# balancer) delante de la app que vos controlás y que garantiza sobreescribir
# X-Forwarded-For/X-Real-Ip (nunca reenvía el valor que manda el cliente).
# Sin eso, dejalo en "false": cualquiera puede falsificar esos headers y
# saltarse el rate-limit de login/registro por IP.
# En el VPS con Caddy delante (app en 127.0.0.1:8147, inalcanzable directo):
# poné "true" — Caddy es el proxy de confianza acá.
TRUST_PROXY_HEADERS=false
